{
  "name": "myelec",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,api -c cyan,magenta \"vite\" \"node server.js\"",
    "dev:vite": "vite",
    "dev:api": "node server.js",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "icons": "rm -rf .icons-tmp && mkdir .icons-tmp && qlmanage -t -s 180 -o .icons-tmp src/assets/icon.svg >/dev/null && mv .icons-tmp/icon.svg.png public/apple-touch-icon.png && cp src/assets/icon.svg public/favicon.svg && rm -rf .icons-tmp && echo 'Icons regenerated in public/'"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.16",
    "@types/express": "^5.0.4",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^5.2.0",
    "globals": "^17.6.0",
    "tailwindcss": "^4.1.16",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
